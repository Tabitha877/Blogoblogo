<%- include("partials/header.ejs") %>

<container class="web-page">
    <div class="pageContent">
        <div class="blockContent">
            <h1 class="henny-penny-regular"> Log In </h1>
            <form id="loginContainer" action="/check" method="post">
                <label for="userName">User name:</label>
                <input type="text" id="userName" name="userName" required>
                <label for="password">Password:</label>
                <input type="password" id="password" name="password" required>
                <input type="submit" value="Login" class="button-style">
            </form>
            
            <div id="passwordHelp">
                <p>User name: guest</p>
                <p>Password: knockKnock</p>
            </div>
        </div>
        <% if (locals.message) { %>
            <div id="errorMsg"><%= message %></div>
        <% } %>
    </div>

</container>

<%- include("partials/footer.ejs") %>