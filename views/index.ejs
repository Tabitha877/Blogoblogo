<%- include("partials/header.ejs") %>
<container class="web-page">

    <div id="home-page">
        <div class="head-posts">
            <h1 class="henny-penny-regular">Blogs</h1>
            <form name="deleteAll" id="delete-btn-form" action="/delete" method="post">
                <button id="delete-all" class="chicle-regular">Delete All</button>
            </form>
        </div>
        
        
        <div class="text-block">
            <% if(posts.length > 0) {
                for (let i=posts.length - 1; i >= 0; i--) { %>
                <% let postCount = posts[i] %>
                <% let currentTitle = postCount.title %>
                <% let currentMsg = postCount.post %>
                
                <h2 class="henny-penny-regular"><%= currentTitle %></h2>
                <div class="text-content blog-post">
                    <p><%= currentMsg %></p>
                    <form name="editButton" id="edit-button" action="/edit" method="post">
                        <input type="hidden" name="title" value="<%= currentTitle %>">
                        <input type="hidden" name="post" value="<%= currentMsg %>">
                        <button>Edit</button>
                    </form>
                    <form id="delete-one" name="deleteOne" action="/delete-one" method="post">
                        <input type="hidden" name="title" value="<%= currentTitle %>">
                        <button>Delete</button>
                    </form>
                        
                </div>
                <% } %>
            <% } else { %>
                <p class="chicle-regular" id="no-posts-msg">No posts to display</p>
            <% } %>
        </div>     
    </div>
        

</container>
<%- include("partials/footer.ejs") %>
